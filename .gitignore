# Windows reserved device names (Win32 refuses these as filenames on Windows hosts).
# Git on Windows errors out with messages like "invalid path 'nul'" when
# such a path appears in the index / checkout / add.
# The bare token matches a path component at any depth (so `foo/nul` is
# also covered); the `.<ext>` variant hits Win32's rule that any
# extension leaves the reserved base name reserved (so `nul.txt` is also
# forbidden). On case-insensitive Windows filesystems these match
# NUL/Nul/Con/COM1/.../LPT9 regardless of case.
# See https://learn.microsoft.com/en-us/windows/win32/fileio/naming-a-file
nul
nul.*
con
con.*
aux
aux.*
prn
prn.*
com1
com1.*
com2
com2.*
com3
com3.*
com4
com4.*
com5
com5.*
com6
com6.*
com7
com7.*
com8
com8.*
com9
com9.*
lpt1
lpt1.*
lpt2
lpt2.*
lpt3
lpt3.*
lpt4
lpt4.*
lpt5
lpt5.*
lpt6
lpt6.*
lpt7
lpt7.*
lpt8
lpt8.*
lpt9
lpt9.*
